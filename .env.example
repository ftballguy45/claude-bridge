# Required — Claude Code OAuth token. Bills against your Claude subscription.
#   claude --print-oauth-token
CLAUDE_CODE_OAUTH_TOKEN=

# Listen port inside the bridge process. In Docker, consumers remap via
# ports: ["<host>:3100"], so this rarely needs overriding.
PORT=3100

# Claude SDK session TTL (ms).
SESSION_TTL_MS=1800000

# Optional — Dwell server base URL. When set, the bridge fire-and-forget POSTs
# a per-turn record to <DWELL_ACTIVITY_URL>/api/ai/activity so every voice/AI
# turn shows up in Dwell's AI Activity page (instead of tailing logs). Leave
# blank to disable reporting (the turn itself is never affected either way).
# Use the SAME base URL you set as "Dwell URL" in the HA Claude Bridge
# integration — it must be reachable from wherever this bridge container runs.
# Dwell's API listens on :5248. NO trailing /api/ai/activity (code appends it).
# Set this per-deployment in the container's environment, not in source.
#   e.g. DWELL_ACTIVITY_URL=http://<dwell-host>:5248
DWELL_ACTIVITY_URL=

LOG_LEVEL=info

# "generic"       — skip HA MCP spawn + warmup (any non-HA consumer)
# "home-assistant" — enable MCP child-process + HA system prompt warmup
BRIDGE_MODE=generic

# Only used when BRIDGE_MODE=home-assistant. Paths to the HA MCP server
# binary and its cwd. Defaults assume the HomeAssistantAutomationService
# checkout at F:/Code/Scratch/AI/AI Generated UIs/HomeAssistantAutomationService.
# HA_MCP_COMMAND=F:/path/to/HomeAssistantMcp.exe
# HA_PROJECT_CWD=F:/path/to/HomeAssistantAutomationService

# Optional supplemental debug log (stdout is the primary sink).
# LOG_FILE=/tmp/bridge.log
